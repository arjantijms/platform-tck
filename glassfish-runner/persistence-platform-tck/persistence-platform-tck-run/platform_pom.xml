    <artifactId>glassfish.jpa-platform-tck-appclient</artifactId>
    
    <dependencies>
        <dependency>
            <groupId>jakarta.tck.arquillian</groupId>
            <artifactId>arquillian-protocol-appclient</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <artifactId>maven-failsafe-plugin</artifactId>
                <executions>
                    <execution>
                        <id>jpa-tests-appclient</id>
                        <goals>
                            <goal>integration-test</goal>
                            <goal>verify</goal>
                        </goals>
                        <configuration>
                            <groups>platform</groups>
                            <systemPropertyVariables>
                                <arquillian.xml>appclient-arquillian.xml</arquillian.xml>
                                <ts.home>${ts.home}</ts.home>
                            </systemPropertyVariables>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- App client profiles -->
    
        <profile>
            <id>ee</id>
            <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
