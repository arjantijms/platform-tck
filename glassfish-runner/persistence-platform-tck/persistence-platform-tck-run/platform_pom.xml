                <plugins>
                    <plugin>
                        <artifactId>maven-failsafe-plugin</artifactId>
                        <executions>
                            <execution>
                                <id>jpa-tests-appclient</id>
                                <configuration>
                                    <includes>
                                        <include>ee/jakarta/tck/persistence/ee/**/*Test.java</include>
                                    </includes>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>
                </plugins>
            </build>
